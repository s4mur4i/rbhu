# RBHU PSD2 sandbox credentials (copy to secrets/.env and fill in).
# Obtain from the RBI API Marketplace application dashboard.
client_id=your_client_id
client_secret=your_client_secret
redirect_url=https://api.rbinternational.com/swagger-ui-oauth2-redirect
# SHA-256 fingerprint of your eIDAS / sandbox client certificate.
eidas=AA:BB:CC:...
